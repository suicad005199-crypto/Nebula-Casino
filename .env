# Supabase 配置 (請從 Supabase Dashboard > Settings > API 取得)
# -----------------------------------------------------------
# 專案的 API 網址
SUPABASE_URL=https://your-project-url.supabase.co

# 匿名金鑰 (Anon Key)，用於前端 API 請求
SUPABASE_ANON_KEY=your-anon-key-here

# 服務角色金鑰 (Service Role Key)，僅限後端使用，切勿外洩
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 遊戲供應商 API 設定 (範例)
# -----------------------------------------------------------
# DG_API_ENDPOINT=https://api.dg.com
# DG_APP_ID=your-app-id
